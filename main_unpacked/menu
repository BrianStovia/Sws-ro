#!/usr/bin/env bash



# Variabel
domain=$(cat /usr/local/etc/v2ray/domain)
ml=$(echo "$(lsb_release -ds) [ $(uname -m) ]")
tram=$(free -m | awk 'NR==2 {print $2}')
versi=$($(which v2ray) version | grep "V2Ray" | awk '{print $2}')

# Data IP VPS
ipsaya=$(curl -s http://checkip.amazonaws.com)
asn_info=$(timeout 5 curl -s "http://ip-api.com/json/$ipsaya" | jq -r '.isp // "Unknown ISP"')

# === WARNA ===
RED='\e[31m'
GREEN='\e[32m'
WHITE='\e[97m'
NC='\e[0m' # No Color

# === FUNGSI STATUS SERVICE ===
check_service() {
    systemctl is-active --quiet "$1" && echo -e "${GREEN}ON${NC}" || echo -e "${RED}OFF${NC}"
}

# === FUNGSI PROGRESS BAR RESOURCE ===
draw_bar() {
    local percent=$1
    local width=15
    local filled=$(( percent * width / 100 ))
    local empty=$(( width - filled ))
    local bar=""
    local color=""
    if [ $percent -le 50 ]; then
        color="${GREEN}"
    elif [ $percent -le 80 ]; then
        color="\e[33m"
    else
        color="${RED}"
    fi
    for ((i=0; i<filled; i++)); do
        bar+="${color}█${NC}"
    done
    for ((i=0; i<empty; i++)); do
        bar+="░"
    done
    echo -e "${bar} ${percent}%"
}

# total akun
shc=$(awk -F: '$3 >= 1000 && $1 != "nobody" {print $1}' /etc/passwd | wc -l)
trojan=$(cat /usr/local/etc/v2ray/config.json | grep "#!" | sort | uniq | wc -l)
vless=$(cat /usr/local/etc/v2ray/config.json | grep "#&" | sort | uniq | wc -l)
vmess=$(cat /usr/local/etc/v2ray/config.json | grep "###" | sort | uniq | wc -l)
ss=$(cat /usr/local/etc/v2ray/config.json | grep "###&" | sort | uniq | wc -l)

# Status service
sv2ray=$(check_service v2ray)
snginx=$(check_service nginx)
sslh=$(check_service sslh)

warp_menu() {
    clear
    # Check if warp-cli is installed
    if ! command -v warp-cli &>/dev/null; then
        warp_installed="❌ Belum Terinstal"
        warp_status="OFF"
    else
        warp_installed="✅ Terinstal"
        # Check if connected
        if warp-cli status 2>/dev/null | grep -q "Connected"; then
            warp_status="ON"
        else
            warp_status="OFF"
        fi
    fi

    # Check if outbound is socks proxy on 40000 in config.json
    v2ray_warp="OFF"
    if [ -f "/usr/local/etc/v2ray/config.json" ] && grep -q -E '"port"\s*:\s*40000' /usr/local/etc/v2ray/config.json; then
        v2ray_warp="ON"
    fi

    # Check if SOCKS5 proxy is actually working and has internet
    warp_internet="❌ Offline"
    if [ "$warp_status" == "ON" ]; then
        echo -e "Memeriksa akses internet WARP..."
        if curl -s --socks5-hostname 127.0.0.1:40000 --connect-timeout 3 https://www.cloudflare.com/cdn-cgi/trace | grep -q "warp=on"; then
            warp_internet="✅ Aktif (Internet OK)"
        else
            warp_internet="❌ Gangguan (Tanpa Internet)"
        fi
        clear
    fi

    echo -e "======================================"
    echo -e "         CLOUDFLARE WARP MENU         "
    echo -e "======================================"
    echo -e " Status Aplikasi  : ${warp_installed}"
    echo -e " Koneksi WARP CLI : ${warp_status}"
    echo -e " Proxy V2Ray      : ${v2ray_warp}"
    echo -e " Akses Internet   : ${warp_internet}"
    echo -e "======================================"
    echo -e " 1. Aktifkan Cloudflare WARP (ON)"
    echo -e " 2. Nonaktifkan Cloudflare WARP (OFF)"
    echo -e " 3. Install & Setup Cloudflare WARP"
    echo -e " 0. Kembali ke Menu Utama"
    echo -e "======================================"
    read -p "Pilihan Anda: " warp_opt
    case $warp_opt in
        1)
            clear
            if ! command -v warp-cli &>/dev/null; then
                echo "Error: Cloudflare WARP belum terinstal. Silakan pilih opsi 3 terlebih dahulu."
                sleep 3
                warp_menu
                return
            fi
            echo "Menghubungkan ke Cloudflare WARP..."
            # Pastikan daemon warp-svc aktif terlebih dahulu
            systemctl start warp-svc &>/dev/null
            sleep 1.5
            # Selalu pastikan mode proxy aktif sebelum connect untuk mencegah VPS lockout
            warp-cli --accept-tos disconnect &>/dev/null
            warp-cli --accept-tos set-mode proxy &>/dev/null || warp-cli --accept-tos mode proxy &>/dev/null
            warp-cli --accept-tos set-proxy-port 40000 &>/dev/null || warp-cli --accept-tos proxy port 40000 &>/dev/null
            warp-cli --accept-tos connect &>/dev/null
            sleep 2
            
            # Change outbound in config.json to socks proxy
            python3 /usr/local/sbin/toggle_warp.py enable
            systemctl restart v2ray
            echo "Cloudflare WARP berhasil diaktifkan!"
            sleep 2
            warp_menu
            ;;
        2)
            clear
            if ! command -v warp-cli &>/dev/null; then
                echo "Error: Cloudflare WARP belum terinstal."
                sleep 3
                warp_menu
                return
            fi
            echo "Memutuskan koneksi Cloudflare WARP..."
            warp-cli --accept-tos disconnect &>/dev/null
            sleep 2
            
            # Change outbound in config.json back to freedom with UseIPv4
            python3 /usr/local/sbin/toggle_warp.py disable
            systemctl restart v2ray
            echo "Cloudflare WARP berhasil dinonaktifkan!"
            sleep 2
            warp_menu
            ;;
        3)
            clear
            echo "Memulai instalasi Cloudflare WARP..."
            # Check if warp-cli is already installed
            if command -v warp-cli &>/dev/null; then
                echo "Cloudflare WARP sudah terinstal."
                sleep 2
                warp_menu
                return
            fi
            
            # Ensure prerequisites are installed
            echo "Menginstal prasyarat (curl, gnupg, lsb-release)..."
            apt-get update -y &>/dev/null
            apt-get install -y curl gnupg lsb-release &>/dev/null
            mkdir -p /usr/share/keyrings
            
            # Install cloudflare-warp
            echo "Mengunduh dan memasang repositori Cloudflare WARP..."
            curl -fsSL https://pkg.cloudflareclient.com/pubkey.gpg | gpg --yes --dearmor --output /usr/share/keyrings/cloudflare-warp-archive-keyring.gpg
            echo "deb [arch=amd64 signed-by=/usr/share/keyrings/cloudflare-warp-archive-keyring.gpg] https://pkg.cloudflareclient.com/ $(lsb_release -cs) main" | tee /etc/apt/sources.list.d/cloudflare-client.list
            apt-get update -y && apt-get install cloudflare-warp -y
            systemctl daemon-reload
            systemctl enable warp-svc && systemctl start warp-svc
            sleep 2
            
            echo "Mendaftarkan client WARP..."
            # Fallback registration commands
            if ! warp-cli --accept-tos registration new &>/dev/null; then
                warp-cli --accept-tos register &>/dev/null
            fi
            
            # Pastikan mode proxy aktif sebelum setting atau connect
            warp-cli --accept-tos disconnect &>/dev/null
            # Fallback mode/port commands
            warp-cli --accept-tos set-mode proxy &>/dev/null || warp-cli --accept-tos mode proxy &>/dev/null
            warp-cli --accept-tos set-proxy-port 40000 &>/dev/null || warp-cli --accept-tos proxy port 40000 &>/dev/null
            
            echo "Instalasi selesai!"
            sleep 3
            warp_menu
            ;;
        *)
            menu
            ;;
    esac
}

clear
echo -e "─────────────────────────────────────────────────────"
